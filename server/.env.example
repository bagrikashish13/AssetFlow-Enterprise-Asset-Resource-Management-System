# Copy to .env and adjust. All variables are validated at boot (src/config/env.validation.ts).

NODE_ENV=development
PORT=3000

# PostgreSQL — matches docker-compose.yml defaults
DATABASE_URL=postgresql://assetflow:assetflow_dev@localhost:5432/assetflow?schema=public

# Auth — use a long random string (min 32 chars) in every environment
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=8h

# CORS allowlist — the SPA origin
CLIENT_ORIGIN=http://localhost:5173

# File uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5

# Global rate limit (requests per TTL seconds); auth endpoints are stricter
THROTTLE_TTL=60
THROTTLE_LIMIT=100
